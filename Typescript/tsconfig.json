{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build/js",

    "module": "ESNext",
    "target": "ES2020",

    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "strict": true,
    "jsx": "react-jsx",

    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["src"]
}